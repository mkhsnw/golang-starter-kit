func new{{.Pascal}}Usecase(t *testing.T) (*usecase.{{.Pascal}}Usecase, *mocks.{{.Pascal}}RepositoryInterface) {
	t.Helper()
	repoMock := new(mocks.{{.Pascal}}RepositoryInterface)
	logger := logrus.New()
{{- if .IsTx}}
	uc := usecase.New{{.Pascal}}Usecase(logger, &dummyTxManager{}, repoMock)
