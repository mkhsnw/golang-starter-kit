// GetAll godoc
// @Summary Get all {{.Plural}}
// @Description Get a paginated list of {{.Plural}}
// @Tags {{.Plural}}
// @Produce json
// @Param page query int false "Page number"
// @Param size query int false "Page size"
// @Success 200 {object} response.Response
// @Router /{{.Plural}} [get]
func (c *{{.Pascal}}Controller) GetAll(ctx fiber.Ctx) error {
	page := 1; if p, err := strconv.Atoi(ctx.Query("page", "1")); err == nil { page = p }
	size := 10; if s, err := strconv.Atoi(ctx.Query("size", "10")); err == nil { size = s }

	res, total, err := c.Service.GetAll(ctx.Context(), page, size)
	if err != nil {
		return err
	}

	totalPages := int(total) / size
	if int(total)%size > 0 {
		totalPages++
	}
	hasNext := page < totalPages
	hasPrev := page > 1

	paging := mapper.MapPagination(page, size, total, totalPages, hasNext, hasPrev, "")
	return response.Page(res).Paging(paging).Send(ctx)
}