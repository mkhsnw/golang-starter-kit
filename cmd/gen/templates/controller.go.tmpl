// @Router /{{.Plural}} [get]
func (c *{{.Pascal}}Controller) GetAll(ctx fiber.Ctx) error {
	cursor := ctx.Query("cursor", "")
	size, _ := strconv.Atoi(ctx.Query("size", "10"))

	// Guard: Cegah abuse pagination
	if size < 1 || size > 100 {
		size = 10
	}

	responses, nextCursor, err := c.{{.Pascal}}Usecase.GetAll(ctx.Context(), cursor, size)
	if err != nil {
		return err
	}
	return ctx.JSON(model.WebResponse[[]model.{{.Pascal}}Response]{
		Data:  responses,
		Paging: &model.PageMetadata{
			Size:       size,
			NextCursor: nextCursor,
		},
	})
}

