package seed

import (
	"log"

	"{{.ModuleName}}/db/factory"
{{- if .HasForeignKey }}
	"{{.ModuleName}}/internal/module/{{.Snake}}"
{{- end }}
	"gorm.io/gorm"
)

type {{.Pascal}}Seeder struct {
	factory *factory.{{.Pascal}}Factory
}

func New{{.Pascal}}Seeder() *{{.Pascal}}Seeder {
	return &{{.Pascal}}Seeder{
		factory: factory.New{{.Pascal}}Factory(),
	}
}

func (s *{{.Pascal}}Seeder) Name() string {
	return "{{.Pascal}}Seeder"
}

func (s *{{.Pascal}}Seeder) Seed(db *gorm.DB) error {
	if err := TruncateTables(db, "{{.Plural}}"); err != nil {
		return err
	}

{{- range .Fields }}
{{- if .IsForeignKey }}
	// Fetch existing master IDs from table '{{.ReferencedTable}}'
	{{.SnakeName}}s, _ := GetExistingIDs(db, "{{.ReferencedTable}}")
{{- end }}
{{- end }}

	count := GetSeedCount(10)
	items := s.factory.BuildBatch(count{{- if .HasForeignKey }}, func(idx int, item *{{.Snake}}.{{.Pascal}}) {
{{- range .Fields }}
{{- if .IsForeignKey }}
		if len({{.SnakeName}}s) > 0 {
			item.{{.PascalName}} = RandomChoice({{.SnakeName}}s)
		}
{{- end }}
{{- end }}
	}{{- end }})

	if err := ExecWithoutFK(db, func() error {
		return db.Create(&items).Error
	}); err != nil {
		return err
	}

	log.Printf("-------------------------------------------\n")
	log.Printf("📦 Seeded {{.Pascal}} (%d records)\n", len(items))
	log.Printf("-------------------------------------------\n")

	return nil
}

