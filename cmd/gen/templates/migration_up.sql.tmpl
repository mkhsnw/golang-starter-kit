CREATE TABLE {{.Plural}} (
    id VARCHAR(36) PRIMARY KEY,
{{- range .Fields}}
    {{.SnakeName}} {{.SQLType}} {{if .Nullable}}NULL{{else}}NOT NULL{{end}},
{{- end}}
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP
{{- range .Fields}}
{{- if .IsForeignKey}}
    ,CONSTRAINT fk_{{$.Plural}}_{{.SnakeName}} FOREIGN KEY ({{.SnakeName}}) REFERENCES {{.ReferencedTable}}(id) ON DELETE CASCADE
{{- end}}
{{- end}}
);

{{- range .Fields}}
{{- if .IsForeignKey}}
CREATE INDEX idx_{{$.Plural}}_{{.SnakeName}} ON {{$.Plural}}({{.SnakeName}});
{{- end}}
{{- end}}
