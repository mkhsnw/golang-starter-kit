// ─── Helper ──────────────────────────────────────────────────────────────────

func setup{{.Pascal}}Controller(t *testing.T) (*fiber.App, *ucmocks.{{.Pascal}}UsecaseInterface) {
	t.Helper()
	ucMock := new(ucmocks.{{.Pascal}}UsecaseInterface)
	validate := validator.New()
	ctrl := controller.New{{.Pascal}}Controller(ucMock, validate)

	// Use the same error handler as production (config.NewErrorHandler)
	// so that validator errors return 400, not 500.
	app := fiber.New(fiber.Config{
		ErrorHandler: config.NewErrorHandler(),
	})
	app.Post("/{{.Plural}}", ctrl.Create)
	app.Get("/{{.Plural}}", ctrl.GetAll)
	app.Get("/{{.Plural}}/:id", ctrl.GetByID)
	app.Put("/{{.Plural}}/:id", ctrl.Update)
	app.Delete("/{{.Plural}}/:id", ctrl.Delete)

	return app, ucMock
}

