func Test{{.Pascal}}Controller_Create_Success(t *testing.T) {
	app, ucMock := setup{{.Pascal}}Controller(t)

	ucMock.On("Create", mock.Anything, mock.Anything).
		Return(&model.{{.Pascal}}Response{}, nil).Maybe()

	req := httptest.NewRequest("POST", "/{{.Plural}}", bytes.NewReader(validCreate{{.Pascal}}Body()))
	req.Header.Set("Content-Type", "application/json")

	resp, _ := app.Test(req)

	// If validator rejects the empty body → StatusBadRequest, otherwise StatusCreated.
	// Populate validCreate{{.Pascal}}Body() above with real field values to get StatusCreated.
	assert.True(t, resp.StatusCode == fiber.StatusCreated || resp.StatusCode == fiber.StatusBadRequest)
	ucMock.AssertExpectations(t)
}

func Test{{.Pascal}}Controller_Create_ValidationError(t *testing.T) {
	app, ucMock := setup{{.Pascal}}Controller(t)

	// Send empty body — validator should reject it
	req := httptest.NewRequest("POST", "/{{.Plural}}", bytes.NewReader([]byte(`{}`)))
	req.Header.Set("Content-Type", "application/json")

	resp, err := app.Test(req)

	assert.NoError(t, err)
	assert.Equal(t, fiber.StatusBadRequest, resp.StatusCode)
	ucMock.AssertNotCalled(t, "Create")
}

