func Test{{.Pascal}}Controller_Create_ValidationError(t *testing.T) {
	app, ucMock := setup{{.Pascal}}Controller(t)

	// Send empty body — validator should reject it
	req := httptest.NewRequest("POST", "/{{.Plural}}", bytes.NewReader([]byte(`{}`)))
	req.Header.Set("Content-Type", "application/json")

	resp, err := app.Test(req)

	assert.NoError(t, err)
	assert.Equal(t, fiber.StatusBadRequest, resp.StatusCode)
	ucMock.AssertNotCalled(t, "Create")
}
