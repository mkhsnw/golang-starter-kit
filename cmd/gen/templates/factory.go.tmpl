func (f *{{.Pascal}}Factory) BuildBatch(count int, overrides ...func(int, *{{.Snake}}.{{.Pascal}})) []*{{.Snake}}.{{.Pascal}} {
	items := make([]*{{.Snake}}.{{.Pascal}}, 0, count)
	for i := 1; i <= count; i++ {
		idx := i
		item := f.Build()
		for _, override := range overrides {
			override(idx, item)
		}
		items = append(items, item)
	}
	return items
}
