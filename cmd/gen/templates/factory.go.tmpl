{{- else if or (hasSuffix .SnakeName "desc") (hasSuffix .SnakeName "description") (hasSuffix .SnakeName "note") }}
		{{ .PascalName }}: gofakeit.Sentence(8),
{{- else if eq .RawType "text" }}
