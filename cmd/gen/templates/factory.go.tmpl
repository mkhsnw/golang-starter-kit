{{- end }}
{{- else if or (eq .Type "int") (eq .Type "int32") (eq .Type "int64") (eq .Type "uint") (eq .Type "uint32") (eq .Type "uint64") }}
{{- if or (hasSuffix .SnakeName "price") (hasSuffix .SnakeName "amount") (hasSuffix .SnakeName "cost") }}
		{{ .PascalName }}: {{ .Type }}(gofakeit.Number(10000, 500000)),
{{- else }}
		{{ .PascalName }}: {{ .Type }}(gofakeit.Number(1, 100)),
{{- end }}
{{- else if or (eq .Type "float32") (eq .Type "float64") }}
		{{ .PascalName }}: {{ .Type }}(gofakeit.Price(10.0, 500.0)),
{{- else if eq .Type "bool" }}
