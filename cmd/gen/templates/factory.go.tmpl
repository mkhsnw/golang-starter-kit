func (f *{{.Pascal}}Factory) Build(overrides ...func(*{{.Snake}}.{{.Pascal}})) *{{.Snake}}.{{.Pascal}} {
	item := &{{.Snake}}.{{.Pascal}}{
		ID:        uuid.Must(uuid.NewV7()).String(),
{{- range .Fields }}
